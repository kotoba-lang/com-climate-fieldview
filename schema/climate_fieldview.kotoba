// Climate_fieldview clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace climate_fieldview {

    entity Field {
        id: string @unique
        name: string
        areaHa: float
        crop: string
        lat: float
        lon: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Operation {
        id: string @unique
        fieldId: string
        type: string
        date: datetime
        rate: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Reading {
        id: string @unique
        fieldId: string
        parameter: string
        value: float
        recordedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Machine {
        id: string @unique
        model: string
        serial: string
        hoursUsed: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Lot {
        id: string @unique
        productName: string
        harvestId: string
        quantity: float
        traceCode: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Imagery {
        id: string @unique
        fieldId: string
        index: string
        capturedAt: datetime
        contentRef: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
